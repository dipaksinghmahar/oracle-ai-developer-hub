# ============================================================================
# RAG on Oracle AI Database 26ai - Environment Configuration
# ============================================================================
#
# Copy this file to .env (the file Python actually reads):
#   cp .env.example .env
#
# The defaults below work out of the box with the docker-compose.yml in this
# repo. You shouldn't need to change anything to run the demo locally.
# ============================================================================


# ----------------------------------------------------------------------------
# DATABASE: ADMIN CREDENTIALS
# ----------------------------------------------------------------------------
# Used ONLY by seed.py for one-time setup (creating the demo user, granting
# privileges, registering the ONNX directory). The application itself never
# connects with these credentials.
#
# These match the ORACLE_PWD value in docker-compose.yml. If you change the
# password there, change it here too.
# ----------------------------------------------------------------------------

ORACLE_ADMIN_USER=system
ORACLE_ADMIN_PASSWORD=Welcome12345


# ----------------------------------------------------------------------------
# DATABASE: APPLICATION USER
# ----------------------------------------------------------------------------
# The dedicated user that owns the DOC_CHUNKS table, the embedding model, and
# the vector index. Created automatically by seed.py if it doesn't exist.
#
# All retrieval queries (from app.py) connect as this user.
# ----------------------------------------------------------------------------

ORACLE_USER=raguser
ORACLE_PASSWORD=RagUser_2026


# ----------------------------------------------------------------------------
# DATABASE: CONNECTION
# ----------------------------------------------------------------------------
# Connection string for python-oracledb (host:port/service_name format).
# Default points at the local Docker container.
# ----------------------------------------------------------------------------

ORACLE_DSN=localhost:1521/FREEPDB1


# ----------------------------------------------------------------------------
# FILE SYSTEM PATHS
# ----------------------------------------------------------------------------
# DATA_DIR:    where the ONNX model and source PDFs are downloaded on the host
# DB_ONNX_DIR: the same path as the database sees it (mounted via Docker)
# ----------------------------------------------------------------------------

DATA_DIR=./data
DB_ONNX_DIR=/opt/oracle/data


# ----------------------------------------------------------------------------
# LOCAL LLM (OLLAMA)
# ----------------------------------------------------------------------------
# The local language model used to generate grounded answers. Free, runs on
# your machine, no API key needed.
# ----------------------------------------------------------------------------

OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
